# ──────────────────────────────────────────────────────────────────────────
# SUDO Portal Backend — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ── Node ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info                              # trace|debug|info|warn|error|fatal

# ── Database ──────────────────────────────────────────────────────────────
# Local dev (Docker Compose): postgres://sudo:sudo@db:5432/sudo_portal
# Production: postgres://USER:PASS@host:5432/sudo_portal?sslmode=require
DATABASE_URL=postgres://sudo:sudo@db:5432/sudo_portal

# ── JWT session signing ────────────────────────────────────────────────────
# Generate a fresh secret per environment with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_64_RANDOM_HEX_CHARS_FROM_OPENSSL_RAND_HEX_64
JWT_EXPIRES_IN=8h

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed Origins for browser requests.
# Match this to wherever the HTML portals are served from.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://portal.sudoconsultants.com

# ── Microsoft 365 / Entra ID OIDC ──────────────────────────────────────────
# Required for user sign-in. Without these, /auth/login will 503.
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=replace-with-app-registration-client-secret
ENTRA_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback
ENTRA_POST_LOGOUT_REDIRECT_URI=http://localhost:8080/

# Group → SUDO role mapping (object IDs of the Entra groups)
# Leave any blank to disable that role mapping path.
ENTRA_GROUP_ADMIN=
ENTRA_GROUP_HR=
ENTRA_GROUP_PM=
ENTRA_GROUP_TL=
ENTRA_GROUP_EMPLOYEE=
ENTRA_GROUP_FINANCE=
ENTRA_GROUP_RECRUITER=
ENTRA_GROUP_AUDITOR=

# Space-separated scopes for the access token used to call Graph
M365_GRAPH_SCOPES=User.Read User.Read.All Group.Read.All Calendars.ReadWrite OnlineMeetings.ReadWrite Mail.Send

# ── ODOO integration (stub for now) ────────────────────────────────────────
ODOO_BASE_URL=
ODOO_DB=
ODOO_API_KEY=

# ── Webhook signing secret ─────────────────────────────────────────────────
# Used to verify HMAC signatures on inbound webhooks AND to sign outbound ones.
WEBHOOK_SIGNING_SECRET=replace-with-32-random-hex

# ── Optional: Slack notifications ──────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Optional: SES / SMTP for outbound email ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@sudoconsultants.com
SMTP_FROM_NAME=SUDO Portal

# ── Seed behaviour ─────────────────────────────────────────────────────────
# When true, seed:reset is allowed (wipes all data). MUST be false in prod.
ALLOW_DESTRUCTIVE_SEED=true
